# ─── Application ─────────────────────────────────────────────────────────────
FLASK_ENV=production
PORT=5000
LOG_LEVEL=INFO

# ─── Security (CHANGE ALL OF THESE IN PRODUCTION) ────────────────────────────
SECRET_KEY=change-me-to-a-random-32-char-string
JWT_SECRET_KEY=change-me-to-a-different-random-32-char-string
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=blockguardian_password
DATABASE_URL=postgresql://blockguardian:blockguardian_password@postgres:5432/blockguardian

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_password
REDIS_URL=redis://:redis_password@redis:6379/0

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://yourfrontend.com

# ─── Monitoring ───────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin_password

# ─── External APIs (optional) ─────────────────────────────────────────────────
INFURA_API_KEY=
ETHERSCAN_API_KEY=
COINMARKETCAP_API_KEY=
ALPHA_VANTAGE_API_KEY=

# ─── Compliance ───────────────────────────────────────────────────────────────
KYC_ENABLED=true
AML_ENABLED=true
GDPR_COMPLIANCE=true
