# BlockGuardian Environment Configuration
# Copy this file to .env and fill in all required values
# NEVER commit .env to version control

# ─────────────────────────────────────────
# Database
# ─────────────────────────────────────────
DB_NAME=blockguardian
DB_USER=bguser
DB_PASSWORD=CHANGE_ME_strong_password_here
DB_ROOT_PASSWORD=CHANGE_ME_root_password_here

# ─────────────────────────────────────────
# Redis
# ─────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password_here

# ─────────────────────────────────────────
# Application Secrets
# ─────────────────────────────────────────
# JWT_SECRET must be at least 32 characters
JWT_SECRET=CHANGE_ME_jwt_secret_minimum_32_characters_long
API_KEY=CHANGE_ME_api_key_here

# ─────────────────────────────────────────
# Grafana
# ─────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_grafana_password

# ─────────────────────────────────────────
# Production only (docker-compose.prod.yml)
# ─────────────────────────────────────────
# IMAGE_TAG=v1.0.0
