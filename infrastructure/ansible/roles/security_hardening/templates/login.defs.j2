# Login Definitions - Financial-Grade Security
# Managed by Ansible

MAIL_DIR        /var/mail
PASS_MAX_DAYS   90
PASS_MIN_DAYS   1
PASS_MIN_LEN    14
PASS_WARN_AGE   14

UID_MIN         1000
UID_MAX         60000
SYS_UID_MIN     201
SYS_UID_MAX     999
GID_MIN         1000
GID_MAX         60000
SYS_GID_MIN     201
SYS_GID_MAX     999

CREATE_HOME     yes
UMASK           027
USERGROUPS_ENAB yes
ENCRYPT_METHOD  SHA512
SHA_CRYPT_MIN_ROUNDS 10000
SHA_CRYPT_MAX_ROUNDS 65536

LOGIN_RETRIES   3
LOGIN_TIMEOUT   60
FAIL_DELAY      4

DEFAULT_HOME    yes
LOG_UNKFAIL_ENAB yes
LOG_OK_LOGINS   yes
SYSLOG_SU_ENAB  yes
SYSLOG_SG_ENAB  yes
