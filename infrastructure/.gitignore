# Terraform
**/.terraform/
*.tfstate
*.tfstate.backup
*.tfstate.lock.info
tfplan
*.tfplan
.terraform.lock.hcl
terraform.tfvars
!terraform.tfvars.example
override.tf
override.tf.json
*_override.tf
*_override.tf.json
crash.log

# Secrets and environment files
.env
.env.*
!.env.example
*.pem
*.key
id_rsa
id_ed25519
*.p12
*.pfx
vault_pass.txt
ansible-vault-password

# Ansible
ansible/inventory/hosts.yml
!ansible/inventory/hosts.example.yml
ansible/*.log
*.retry
ansible/facts_cache/

# Kubernetes secrets (never commit real secrets)
kubernetes/base/app-secrets.yaml
!kubernetes/base/app-secrets.yaml
# Note: app-secrets.yaml is kept as template with placeholder values only

# Logs
logs/
*.log
validation_logs/

# Python
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
venv/
.venv/

# Node
node_modules/
npm-debug.log*
dist/
build/

# OS
.DS_Store
Thumbs.db
*.swp
*.swo

# IDE
.idea/
.vscode/
*.iml
