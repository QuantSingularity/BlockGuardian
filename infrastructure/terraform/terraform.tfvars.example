# BlockGuardian Terraform Variables Example
# Copy this file to environments/<env>/terraform.tfvars and fill in values
# NEVER commit terraform.tfvars files with real credentials

aws_region  = "us-west-2"
environment = "dev"   # dev | staging | prod
app_name    = "blockguardian"

# Network
vpc_cidr              = "10.0.0.0/16"
availability_zones    = ["us-west-2a", "us-west-2b", "us-west-2c"]
public_subnet_cidrs   = ["10.0.1.0/24", "10.0.2.0/24", "10.0.3.0/24"]
private_subnet_cidrs  = ["10.0.4.0/24", "10.0.5.0/24", "10.0.6.0/24"]
database_subnet_cidrs = ["10.0.7.0/24", "10.0.8.0/24", "10.0.9.0/24"]

enable_management_subnet = false
management_subnet_cidrs  = ["10.0.10.0/24", "10.0.11.0/24", "10.0.12.0/24"]

# Compute
instance_type         = "t3.micro"       # t3.micro | t3.medium | t3.large
key_name              = "your-key-name"
instance_profile_name = "blockguardian-dev-ec2-profile"

# Database
db_instance_class = "db.t3.micro"    # db.t3.micro | db.t3.medium | db.t3.large
db_name           = "blockguardian"
db_username       = "bgadmin"
db_engine         = "mysql"
db_family         = "mysql8.0"
# db_password is intentionally omitted — set via:
#   export TF_VAR_db_password="your-secure-password"

default_tags = {
  Terraform   = "true"
  Environment = "dev"
  Project     = "blockguardian"
  ManagedBy   = "terraform"
}
